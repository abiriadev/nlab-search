#### Meilisearch

MEILI_MASTER_KEY=change-me-to-a-long-random-string
# Search-only key. See the README for instructions on creating one.
MEILI_SEARCH_KEY=

#### Indexer

# Meilisearch URL as seen by the indexer.
MEILI_HOST=http://meilisearch:7700
MEILI_INDEX=pages
REPO_URL=https://github.com/ncatlab/nlab-content
REPO_BRANCH=master
# In compose the repo lives on a volume. For fast local dev, bind-mount an existing checkout to this path instead.
REPO_DIR=/data/repo
STATE_DIR=/data/state
POLL_INTERVAL_MINUTES=10
# Optional cap on indexed content length. Empty = no truncation (default).
MAX_CONTENT_CHARS=
INDEX_BATCH_SIZE=1000

#### Frontend

# Browser-reachable Meilisearch URL.
VITE_MEILI_HOST=http://localhost:7700
# Must match the search-only key created by the indexer.
VITE_MEILI_SEARCH_KEY=
VITE_MEILI_INDEX=pages
