{
	"compilerOptions": {
		"target": "es2024",
		"lib": ["ES2024", "DOM", "DOM.Iterable"],
		"module": "esnext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"types": ["vite/client", "node"],
		"baseUrl": ".",
		"paths": { "@/*": ["src/*"] }
	},
	"include": ["src", "vite.config.ts"]
}
