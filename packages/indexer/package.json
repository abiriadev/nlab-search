{
	"name": "@nlab-search/indexer",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"check": "tsc --noEmit",
		"build": "swc src -d dist --strip-leading-paths",
		"start": "node --enable-source-maps --env-file-if-exists .env dist/index.js",
		"start:dev": "tsx --env-file-if-exists .env watch src/index.ts",
		"count": "tsx src/index.ts --count"
	},
	"dependencies": {
		"meilisearch": "^0.54.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@swc/cli": "^0.8.1",
		"@swc/core": "^1.15.41",
		"@types/node": "^22.10.0",
		"tsx": "^4.20.0",
		"typescript": "^5.7.0"
	}
}
